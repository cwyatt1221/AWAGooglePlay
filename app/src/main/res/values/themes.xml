<resources>
    <style name="Theme.AWA" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#2E4C2E</item>
        <item name="colorPrimaryDark">#1E3620</item>
        <item name="colorAccent">#6FA35C</item>
        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/branding_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_branding_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AWA</item>
    </style>
</resources>
